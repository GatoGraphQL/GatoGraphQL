{
    "name": "pop-wp-schema/commentmeta",
    "type": "library",
    "description": "WordPress-specific Comment Meta data model",
    "keywords": ["Gato", "GatoGraphQL", "GraphQL", "PHP", "WP", "commentmeta"],
    "homepage": "https://github.com/PoPWPSchema/commentmeta",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Leonardo Losoviz",
            "email": "leo@getpop.org",
            "homepage": "https://gatographql.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "pop-cms-schema/commentmeta-wp": "^19.0",
        "pop-wp-schema/comments": "^19.0",
        "pop-wp-schema/meta": "^19.0"
    },
    "require-dev": {
        "johnpbloch/wordpress": "^6.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.2",
        "rector/rector": "^2.1",
        "squizlabs/php_codesniffer": "^3.6",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PoPWPSchema\\CommentMeta\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PoPWPSchema\\CommentMeta\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs src tests",
        "fix-style": "phpcbf src tests",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "branch-alias": {
            "dev-master": "19.0-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
