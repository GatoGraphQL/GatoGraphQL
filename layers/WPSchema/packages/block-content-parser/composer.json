{
    "name": "pop-wp-schema/block-content-parser",
    "type": "library",
    "description": "Parse a custom post and retrieve the content from its (Gutenberg) blocks",
    "keywords": ["Gato", "GatoGraphQL", "GraphQL", "PHP", "WP", "block-content-parser"],
    "homepage": "https://github.com/PoPWPSchema/block-content-parser",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Leonardo Losoviz",
            "email": "leo@getpop.org",
            "homepage": "https://gatographql.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "getpop/dom-crawler": "^18.1",
        "getpop/engine-wp": "^18.1"
    },
    "require-dev": {
        "johnpbloch/wordpress": "^6.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.2",
        "rector/rector": "^2.1",
        "squizlabs/php_codesniffer": "^3.6",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PoPWPSchema\\BlockContentParser\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PoPWPSchema\\BlockContentParser\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs src tests",
        "fix-style": "phpcbf src tests",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "branch-alias": {
            "dev-master": "18.1-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
