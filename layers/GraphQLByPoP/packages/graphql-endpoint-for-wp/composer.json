{
    "name": "graphql-by-pop/graphql-endpoint-for-wp",
    "type": "library",
    "description": "Add pretty permalinks for the single GraphQL endpoint, for WordPress",
    "keywords": ["Gato", "GatoGraphQL", "GraphQL", "PHP", "graphql-endpoint-for-wp"],
    "homepage": "https://github.com/GraphQLByPoP/graphql-endpoint-for-wp",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Leonardo Losoviz",
            "email": "leo@getpop.org",
            "homepage": "https://gatographql.com"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "require": {
        "php": "^8.1",
        "pop-api/api-endpoints-for-wp": "^18.1",
        "pop-api/api-graphql": "^18.1"
    },
    "require-dev": {
        "johnpbloch/wordpress": "^6.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.2",
        "rector/rector": "^2.1",
        "squizlabs/php_codesniffer": "^3.6",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "GraphQLByPoP\\GraphQLEndpointForWP\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GraphQLByPoP\\GraphQLEndpointForWP\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs src tests",
        "fix-style": "phpcbf src tests",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "branch-alias": {
            "dev-master": "18.1-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
