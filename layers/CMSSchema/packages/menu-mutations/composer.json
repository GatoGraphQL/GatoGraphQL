{
    "name": "pop-cms-schema/menu-mutations",
    "type": "library",
    "description": "Adds support for menu mutations",
    "keywords": ["Gato", "GatoGraphQL", "GraphQL", "PHP", "menu-mutations"],
    "homepage": "https://github.com/PoPCMSSchema/menu-mutations",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Leonardo Losoviz",
            "email": "leo@getpop.org",
            "homepage": "https://gatographql.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "pop-cms-schema/menus": "^19.0",
        "pop-cms-schema/user-roles": "^19.0",
        "pop-cms-schema/user-state-mutations": "^19.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.2",
        "pop-cms-schema/custompost-mutations": "^19.0",
        "rector/rector": "^2.1",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "PoPCMSSchema\\MenuMutations\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PoPCMSSchema\\MenuMutations\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs src tests",
        "fix-style": "phpcbf src tests",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "19.0-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
