{"translation-revision-date":"","generator":"WP-CLI\/2.13.0-alpha","source":"blocks\/schema-config-payload-types-for-mutations\/build\/index.js","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","lang":"ko","plural-forms":"nplurals=1; plural=0;"},"There were errors connecting to the API: %s":["API\uc5d0 \uc5f0\uacb0\ud558\ub294 \uc911 \uc624\ub958\uac00 \ubc1c\uc0dd\ud588\uc2b5\ub2c8\ub2e4: %s"],"; ":["; "],"[Internal Server Error (500)]:":["[\ub0b4\ubd80 \uc11c\ubc84 \uc624\ub958 (500)]:"],"No GraphQL query provided":["\uc81c\uacf5\ub41c GraphQL \ucffc\ub9ac\uac00 \uc5c6\uc2b5\ub2c8\ub2e4"],"No endpoint provided to execute the GraphQL query":["GraphQL \ucffc\ub9ac\ub97c \uc2e4\ud589\ud560 \uc5d4\ub4dc\ud3ec\uc778\ud2b8\uac00 \uc81c\uacf5\ub418\uc9c0 \uc54a\uc558\uc2b5\ub2c8\ub2e4"],"This documentation is in English. You can read it in your language at %s.":["\uc774 \ubb38\uc11c\ub294 \uc601\uc5b4\ub85c \uc791\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. %s\uc5d0\uc11c \ud55c\uad6d\uc5b4\ub85c \uc77d\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4."],"Documentation for: \"%s\"":["\ub2e4\uc74c\uc5d0 \ub300\ud55c \ubb38\uc11c: \"%s\""],"(not set)":["(\uc124\uc815\ub418\uc9c0 \uc54a\uc74c)"],"(Undefined or unpublished item with ID '%s')":["(ID\uac00 '%s'\uc778 \uc815\uc758\ub418\uc9c0 \uc54a\uc558\uac70\ub098 \uac8c\uc2dc\ub418\uc9c0 \uc54a\uc740 \ud56d\ubaa9)"],"(none selected)":["(\uc120\ud0dd \uc5c6\uc74c)"],"Default (use value defined in the Settings page)":["\uae30\ubcf8\uac12 (\uc124\uc815 \ud398\uc774\uc9c0\uc5d0 \uc815\uc758\ub41c \uac12 \uc0ac\uc6a9)"],"Undefined elements":["\uc815\uc758\ub418\uc9c0 \uc54a\uc740 \uc694\uc18c"],"Hide search":["\uac80\uc0c9 \uc228\uae30\uae30"],"Show search":["\uac80\uc0c9 \ud45c\uc2dc"],"Search":["\uac80\uc0c9"],"Available items":["\uc0ac\uc6a9 \uac00\ub2a5\ud55c \ud56d\ubaa9"],"No items found.":["\ud56d\ubaa9\uc744 \ucc3e\uc744 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4."],"Operations":["\uc791\uc5c5"],"Global Fields":["\uc804\uc5ed \ud544\ub4dc"],"Directives":["\ub514\ub809\ud2f0\ube0c"],"(Undefined entries)":["(\uc815\uc758\ub418\uc9c0 \uc54a\uc740 \ud56d\ubaa9)"],"Fields":["\ud544\ub4dc"],"Default":["\uae30\ubcf8\uac12"],"Payload Types for Mutations":["\ubba4\ud14c\uc774\uc158\uc6a9 \ud398\uc774\ub85c\ub4dc \uc720\ud615"],"Use payload types for mutations":["\ubba4\ud14c\uc774\uc158\uc5d0 \ud398\uc774\ub85c\ub4dc \ud0c0\uc785 \uc0ac\uc6a9"],"Use payload types for mutations, and add fields to query those payload objects":["\ubba4\ud14c\uc774\uc158\uc5d0 \ud398\uc774\ub85c\ub4dc \ud0c0\uc785\uc744 \uc0ac\uc6a9\ud558\uace0, \ud574\ub2f9 \ud398\uc774\ub85c\ub4dc \uac1d\uccb4\ub97c \uc870\ud68c\ud560 \ud544\ub4dc \ucd94\uac00"],"Do not use payload types for mutations (i.e. return the mutated entity)":["\ubba4\ud14c\uc774\uc158\uc5d0 \ud398\uc774\ub85c\ub4dc \ud0c0\uc785\uc744 \uc0ac\uc6a9\ud558\uc9c0 \uc54a\uc74c (\uc989, \ubcc0\uacbd\ub41c \uc5d4\ud2f0\ud2f0\ub97c \uc9c1\uc811 \ubc18\ud658)"],"Use payload types for mutations in the schema?":["\uc2a4\ud0a4\ub9c8\uc5d0\uc11c \ubba4\ud14c\uc774\uc158\uc5d0 \ud398\uc774\ub85c\ub4dc \uc720\ud615\uc744 \uc0ac\uc6a9\ud558\uc2dc\uaca0\uc2b5\ub2c8\uae4c?"],"Either have mutations return a payload object type, or directly the mutated entity.":["\ubba4\ud14c\uc774\uc158\uc774 \ud398\uc774\ub85c\ub4dc \uac1d\uccb4 \ud0c0\uc785\uc744 \ubc18\ud658\ud558\ub3c4\ub85d \ud558\uac70\ub098, \ubcc0\uacbd\ub41c \uc5d4\ud2f0\ud2f0\ub97c \uc9c1\uc811 \ubc18\ud658\ud558\ub3c4\ub85d \ud569\ub2c8\ub2e4."],"Mutations":["\ubba4\ud14c\uc774\uc158"],"Define if to use payload types for mutations in the Schema Configuration":["\uc2a4\ud0a4\ub9c8 \uad6c\uc131\uc5d0\uc11c \ubba4\ud14c\uc774\uc158\uc5d0 \ud398\uc774\ub85c\ub4dc \ud0c0\uc785\uc744 \uc0ac\uc6a9\ud560\uc9c0 \uc815\uc758\ud558\uc138\uc694"]}}}