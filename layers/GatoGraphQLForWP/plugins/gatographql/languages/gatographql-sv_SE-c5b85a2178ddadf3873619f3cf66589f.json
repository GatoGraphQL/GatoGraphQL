{"translation-revision-date":"","generator":"WP-CLI\/2.13.0-alpha","source":"blocks\/schema-config-schema-categories\/build\/index.js","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","lang":"sv","plural-forms":"nplurals=2; plural=(n != 1);"},"There were errors connecting to the API: %s":["Det uppstod fel vid anslutning till API:et: %s"],"; ":["; "],"[Internal Server Error (500)]:":["[Internt serverfel (500)]:"],"No GraphQL query provided":["Ingen GraphQL-fr\u00e5ga angavs"],"No endpoint provided to execute the GraphQL query":["Ingen slutpunkt angavs f\u00f6r att k\u00f6ra GraphQL-fr\u00e5gan"],"This documentation is in English. You can read it in your language at %s.":["Den h\u00e4r dokumentationen \u00e4r p\u00e5 engelska. Du kan l\u00e4sa den p\u00e5 ditt spr\u00e5k p\u00e5 %s."],"Documentation for: \"%s\"":["Dokumentation f\u00f6r: \"%s\""],"(not set)":["(ej angivet)"],"(Undefined or unpublished item with ID '%s')":["(Odefinierat eller opublicerat objekt med ID '%s')"],"(none selected)":["(inget valt)"],"Default (use value defined in the Settings page)":["Standard (anv\u00e4nd v\u00e4rdet som definierats p\u00e5 inst\u00e4llningssidan)"],"Undefined elements":["Odefinierade element"],"Hide search":["D\u00f6lj s\u00f6kning"],"Show search":["Visa s\u00f6kning"],"Search":["S\u00f6k"],"Available items":["Tillg\u00e4ngliga objekt"],"No items found.":["Inga objekt hittades."],"Operations":["Operationer"],"Global Fields":["Globala f\u00e4lt"],"Directives":["Direktiv"],"(Undefined entries)":["(Odefinierade poster)"],"Fields":["F\u00e4lt"],"Use configuration from Settings":["Anv\u00e4nd konfiguration fr\u00e5n Inst\u00e4llningar"],"Customize configuration?":["Anpassa konfiguration?"],"The configuration items below can be customized for endpoints using this Schema Configuration. Otherwise, the general configuration (defined on the Settings page) will be used.":["Konfigurationsobjekten nedan kan anpassas f\u00f6r slutpunkter som anv\u00e4nder denna sch