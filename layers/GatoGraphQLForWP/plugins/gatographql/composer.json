{
    "name": "gatographql/gatographql",
    "type": "wordpress-plugin",
    "description": "Gato GraphQL",
    "keywords": ["Gato", "GatoGraphQL", "GraphQL", "PHP", "WordPress", "GraphQL", "API"],
    "homepage": "https://github.com/GatoGraphQL/gatographql",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Leonardo Losoviz",
            "email": "leo@getpop.org",
            "homepage": "https://gatographql.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "gatographql/external-dependency-wrappers": "^19.0",
        "gatographql/plugin-utils": "^19.0",
        "getpop/engine-wp": "^19.0",
        "getpop/guzzle-http": "^19.0",
        "getpop/mandatory-directives-by-configuration": "^19.0",
        "getpop/markdown-convertor": "^19.0",
        "graphql-by-pop/graphql-clients-for-wp": "^19.0",
        "graphql-by-pop/graphql-endpoint-for-wp": "^19.0",
        "graphql-by-pop/graphql-server": "^19.0",
        "pop-cms-schema/category-mutations-wp": "^19.0",
        "pop-cms-schema/categorymeta-mutations-wp": "^19.0",
        "pop-cms-schema/commentmeta-mutations-wp": "^19.0",
        "pop-cms-schema/custompost-category-mutations-wp": "^19.0",
        "pop-cms-schema/custompost-categorymeta-mutations": "^19.0",
        "pop-cms-schema/custompost-mutations-wp": "^19.0",
        "pop-cms-schema/custompost-tag-mutations-wp": "^19.0",
        "pop-cms-schema/custompost-tagmeta-mutations": "^19.0",
        "pop-cms-schema/custompost-user-mutations-wp": "^19.0",
        "pop-cms-schema/custompostmedia-mutations-wp": "^19.0",
        "pop-cms-schema/custompostmedia-wp": "^19.0",
        "pop-cms-schema/custompostmeta-mutations-wp": "^19.0",
        "pop-cms-schema/media-mutations-wp": "^19.0",
        "pop-cms-schema/menu-mutations-wp": "^19.0",
        "pop-cms-schema/page-mutations-wp": "^19.0",
        "pop-cms-schema/pagemedia-mutations": "^19.0",
        "pop-cms-schema/pagemeta-mutations": "^19.0",
        "pop-cms-schema/post-categories-wp": "^19.0",
        "pop-cms-schema/post-category-mutations": "^19.0",
        "pop-cms-schema/post-categorymeta-mutations": "^19.0",
        "pop-cms-schema/post-mutations": "^19.0",
        "pop-cms-schema/post-tag-mutations": "^19.0",
        "pop-cms-schema/post-tagmeta-mutations": "^19.0",
        "pop-cms-schema/post-tags-wp": "^19.0",
        "pop-cms-schema/postmedia-mutations": "^19.0",
        "pop-cms-schema/postmeta-mutations": "^19.0",
        "pop-cms-schema/tag-mutations-wp": "^19.0",
        "pop-cms-schema/tagmeta-mutations-wp": "^19.0",
        "pop-cms-schema/taxonomyquery-wp": "^19.0",
        "pop-cms-schema/user-avatars-wp": "^19.0",
        "pop-cms-schema/user-roles-wp": "^19.0",
        "pop-cms-schema/usermeta-mutations-wp": "^19.0",
        "pop-schema/directive-commons": "^19.0",
        "pop-schema/http-requests": "^19.0",
        "pop-schema/logger": "^19.0",
        "pop-wp-schema/blocks": "^19.0",
        "pop-wp-schema/commentmeta": "^19.0",
        "pop-wp-schema/comments": "^19.0",
        "pop-wp-schema/custompostmeta": "^19.0",
        "pop-wp-schema/customposts": "^19.0",
        "pop-wp-schema/media": "^19.0",
        "pop-wp-schema/menus": "^19.0",
        "pop-wp-schema/multisite": "^19.0",
        "pop-wp-schema/pagebuilder": "^19.0",
        "pop-wp-schema/pages": "^19.0",
        "pop-wp-schema/posts": "^19.0",
        "pop-wp-schema/settings": "^19.0",
        "pop-wp-schema/site": "^19.0",
        "pop-wp-schema/taxonomymeta": "^19.0",
        "pop-wp-schema/usermeta": "^19.0",
        "pop-wp-schema/users": "^19.0"
    },
    "require-dev": {
        "johnpbloch/wordpress": "^6.6",
        "php-stubs/wp-cli-stubs": "^2.12.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.2",
        "rector/rector": "^2.1",
        "squizlabs/php_codesniffer": "^3.6",
        "symfony/var-dumper": "^6.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "GatoGraphQL\\GatoGraphQL\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GatoGraphQL\\GatoGraphQL\\": "tests"
        }
    },
    "scripts": {
        "build-server": [
            "Composer\\Config::disableProcessTimeout",
            "lando init --source remote --remote-url https://wordpress.org/latest.tar.gz --recipe wordpress --webroot wordpress --name gatographql-dev",
            "@start-server"
        ],
        "start-server": [
            "composer install",
            "lando start"
        ],
        "destroy-server": "lando destroy -y",
        "rebuild-app-and-server": "lando rebuild -y",
        "stop-server": "lando stop",
        "test": "phpunit",
        "check-style": "phpcs src tests",
        "fix-style": "phpcbf src tests",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "branch-alias": {
            "dev-master": "19.0-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "boxuk/wp-muplugin-loader": true,
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "johnpbloch/wordpress-core-installer": true,
            "oomphinc/composer-installers-extender": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
