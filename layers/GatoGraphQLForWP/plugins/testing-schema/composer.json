{
    "name": "gatographql/testing-schema",
    "type": "wordpress-plugin",
    "description": "Addition of elements to the GraphQL schema to test the Gato GraphQL plugin",
    "keywords": ["Gato", "GatoGraphQL", "WordPress", "GraphQL", "API"],
    "homepage": "https://github.com/GatoGraphQL/testing-schema",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Leonardo Losoviz",
            "email": "leo@getpop.org",
            "homepage": "https://gatographql.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "getpop/engine": "^18.1"
    },
    "require-dev": {
        "johnpbloch/wordpress": "^6.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.2",
        "rector/rector": "^2.1",
        "squizlabs/php_codesniffer": "^3.6",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "GatoGraphQL\\TestingSchema\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GatoGraphQL\\TestingSchema\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "check-style": "phpcs src tests",
        "fix-style": "phpcbf src tests",
        "phpstan": "phpstan analyse -l 8 src tests"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "18.1-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "johnpbloch/wordpress-core-installer": true
        }
    },
    "replace": {
        "getpop/component-model": "self.version",
        "getpop/componentrouting": "self.version",
        "getpop/definitions": "self.version",
        "getpop/engine": "self.version",
        "getpop/loosecontracts": "self.version",
        "getpop/root": "self.version"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
