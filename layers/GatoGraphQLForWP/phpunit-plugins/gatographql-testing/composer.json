{
    "name": "phpunit-for-gatographql/gatographql-testing",
    "type": "wordpress-plugin",
    "description": "Utilities for testing Gato GraphQL",
    "keywords": ["Gato", "GatoGraphQL", "GraphQL", "PHP", "WordPress", "GraphQL", "API"],
    "homepage": "https://github.com/PHPUnitForGatoGraphQL/gatographql-testing",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Leonardo Losoviz",
            "email": "leo@getpop.org",
            "homepage": "https://gatographql.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "johnpbloch/wordpress": "^6.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.2",
        "rector/rector": "^2.1",
        "squizlabs/php_codesniffer": "^3.6",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PHPUnitForGatoGraphQL\\GatoGraphQLTesting\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPUnitForGatoGraphQL\\GatoGraphQLTesting\\": "tests"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "johnpbloch/wordpress-core-installer": true
        }
    }
}
